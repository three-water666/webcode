{
  "manifest_version": 3,
  "name": "WebMCP Bridge",
  "version": "0.4.6",
  "description": "Connect Web AI to local MCP Gateway (Zero-Config)",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "notifications"],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*",
    "https://chatgpt.com/*",
    "https://gemini.google.com/*",
    "https://aistudio.google.com/*",
    "https://chat.deepseek.com/*"
  ],
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "prompt.md",
        "prompt_zh.md",
        "train.md",
        "train_zh.md",
        "error_hint.md",
        "error_hint_zh.md"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "http://127.0.0.1:34567/*",
        "http://127.0.0.1:34568/*",
        "http://127.0.0.1:34569/*",
        "http://127.0.0.1:34570/*",
        "http://127.0.0.1:34571/*",
        "http://127.0.0.1:34572/*",
        "http://127.0.0.1:34573/*",
        "http://127.0.0.1:34574/*",
        "http://127.0.0.1:34575/*",
        "http://127.0.0.1:34576/*",
        "http://localhost:34567/*",
        "http://localhost:34568/*",
        "http://localhost:34569/*",
        "http://localhost:34570/*",
        "http://localhost:34571/*",
        "http://localhost:34572/*",
        "http://localhost:34573/*",
        "http://localhost:34574/*",
        "http://localhost:34575/*",
        "http://localhost:34576/*"
      ],
      "js": ["src/content/bridge_loader.ts"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://gemini.google.com/*",
        "https://aistudio.google.com/*",
        "https://chat.deepseek.com/*"
      ],
      "js": ["src/content/main.ts"]
    }
  ]
}